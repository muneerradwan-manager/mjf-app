{
  "info": {
    "name": "MJF App — Multi-Tenant Educational Platform",
    "description": "Full API reference for the MJF multi-tenant educational platform.\n\nSetup:\n1. Set `base_url` variable to your server (default: http://localhost:8000)\n2. Call POST /api/login → copy the token into the `token` variable\n3. Call POST /api/central/current-tenant to select a tenant\n4. All /api/tenant/* routes are now ready to use",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api", "health"] },
            "description": "Check if the API is up and running."
          }
        }
      ]
    },
    {
      "name": "Central — Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] },
            "description": "Authenticate a central user. The test script automatically saves the returned token into the `token` collection variable."
          }
        },
        {
          "name": "Get Authenticated User (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/me", "host": ["{{base_url}}"], "path": ["api", "me"] },
            "description": "Returns the authenticated user with their active tenant and list of accessible tenants."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/logout", "host": ["{{base_url}}"], "path": ["api", "logout"] },
            "description": "Revokes the current Bearer token."
          }
        }
      ]
    },
    {
      "name": "Central — Tenants",
      "item": [
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Al-Nour School\",\n  \"slug\": \"al-nour-school\",\n  \"code\": \"ALNOUR01\",\n  \"email\": \"info@alnour.edu\",\n  \"phone\": \"+966501234567\",\n  \"subscription_id\": 1,\n  \"type\": \"school\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/central/tenants", "host": ["{{base_url}}"], "path": ["api", "central", "tenants"] },
            "description": "Creates a new tenant, provisions a dedicated database, and runs migrations. The authenticated user becomes the owner.\n\ntype: masjed | school | university"
          }
        },
        {
          "name": "Set Current Tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_id\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/central/current-tenant", "host": ["{{base_url}}"], "path": ["api", "central", "current-tenant"] },
            "description": "Sets the active tenant for the authenticated user. Required before calling any /api/tenant/* route."
          }
        }
      ]
    },
    {
      "name": "Tenant — Health",
      "item": [
        {
          "name": "Tenant Health Check",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/tenant/health", "host": ["{{base_url}}"], "path": ["api", "tenant", "health"] },
            "description": "Confirms the correct tenant database is active for the authenticated user."
          }
        }
      ]
    },
